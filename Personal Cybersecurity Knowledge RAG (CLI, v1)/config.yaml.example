chroma:
  persist_dir: "./chroma_db"
  collection_name: "secknowledge"

embedding:
  # The Hugging Face model name to use locally
  model_name: "sentence-transformers/all-MiniLM-L6-v2"

retrieval:
  # Default number of documents to retrieve
  top_k: 5

chunking:
  pdf:
    chunk_size: 500
    chunk_overlap: 50
  watcher:
    # Debounce time in seconds for the file watcher
    debounce_seconds: 2.0
